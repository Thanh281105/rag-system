<edge source="HippoCamp" target="Evaluation Protocol">
  <data key="d7">1.0</data>
  <data key="d8">HippoCamp employs a unified evaluation protocol to assess agent performance on personalized file management tasks.</data>
  <data key="d9">assessment process,evaluation framework</data>
