  <data key="d12">1775147205</data>
  <data key="d13"></data>
</edge>
<edge source="HippoCamp" target="Evidence Retrieval Evaluation">
  <data key="d7">1.0</data>
  <data key="d8">For evidence retrieval tasks, HippoCamp assesses the accuracy and relevance of retrieved files using recall hit rate and F score.</data>
  <data key="d9">evaluation method,task type</data>
  <data key="d10">chunk-a13c5a1b373926d634e6147cd37b5f93</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1775147205</data>
  <data key="d13"></data>
</edge>
<edge source="HippoCamp" target="RAG Methods">
  <data key="d7">1.0</data>
  <data key="d8">RAG methods are evaluated within the context of HippoCamp's experimental results to highlight their weaknesses in multimodal retrieval and hierarchical reasoning.</data>
