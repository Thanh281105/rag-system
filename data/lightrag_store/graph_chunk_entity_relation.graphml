  <data key="d13"></data>
</edge>
<edge source="HippoCamp" target="Question Answering Evaluation">
  <data key="d7">1.0</data>
  <data key="d8">For question answering tasks, HippoCamp uses an LLM-as-a-judge paradigm for evaluating correctness and quality of responses.</data>
  <data key="d9">evaluation method,task type</data>
  <data key="d10">chunk-a13c5a1b373926d634e6147cd37b5f93</data>
