data/raw/
data/raw_nghidinh/
data/processed/
data/vector_db/

# Bỏ qua file cache của thuật toán BM25
*.pkl

# Bỏ qua các định dạng file nặng
*.docx
*.pdf
*.txt
*.json

# (Tùy chọn) Chỉ giữ lại cấu trúc thư mục rỗng của thư mục data
# Nếu muốn đẩy thư mục rỗng lên, hãy tạo 1 file .gitkeep rỗng trong các thư mục đó
!data/.gitkeep
!data/raw/.gitkeep
!data/raw_nghidinh/.gitkeep

